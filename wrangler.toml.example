name = "nadervpn-worker"
main = "worker.js"
compatibility_date = "2024-01-01"

[vars]
# رمز عبور پنل مدیریت - حتماً تغییر دهید!
ADMIN = "your-secure-password-here"

# کلید رمزگذاری - حتماً تغییر دهید!
KEY = "your-encryption-key-here"

# دامنه Worker
HOST = "your-worker.your-subdomain.workers.dev"

# فعال‌سازی دیباگ (اختیاری)
# DEBUG = "true"

# فعال‌سازی اشتراک بهینه (اختیاری)
# BEST_SUB = "true"

# تعداد TCP کانکشن همزمان (اختیاری)
# TCP并发拨号数 = "2"

# آدرس صفحات استاتیک (Cloudflare Pages)
# PAGES_STATIC = "https://your-pages.pages.dev"

# آی‌پی‌های پروکسی (اختیاری - هر کدام با کاما)
# PROXYIP = "162.159.192.10,172.64.147.20"

# فعال‌سازی ریسولو DNS خودکار پروکسی
# PROXYIP_RESOLVE = "true"

# UUID دستی (اختیاری)
# UUID = "your-uuid-here"

#///////////////////////////////////////////////////////
# KV Namespace - ذخیره تنظیمات
#///////////////////////////////////////////////////////
# ابتدا در Cloudflare Dashboard یک KV namespace بسازید
# سپس ID آن را اینجا قرار دهید
[[kv_namespaces]]
binding = "KV"
id = "YOUR_KV_NAMESPACE_ID_HERE"
# title = "NaderVPN_Config"  # نام نمایشی

#///////////////////////////////////////////////////////
# R2 Storage - ذخیره لاگ‌ها (اختیاری)
#///////////////////////////////////////////////////////
# [[r2_buckets]]
# binding = "R2"
# bucket_name = "nadervpn-logs"